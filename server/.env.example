# home.pl SMTP configuration (for domain email)
# Get credentials from home.pl panel → Your domain → Email → Server config
EMAIL_USER=kontakt@galaretkarnia.pl
EMAIL_PASSWORD=your-mailbox-password-from-home-pl

# Business email (where orders go, defaults to EMAIL_USER if not set)
ORDER_EMAIL=kontakt@galaretkarnia.pl

# Frontend URL (for CORS)
FRONTEND_URL=https://galaretkarnia-pl.vercel.app

# Environment
NODE_ENV=production
PORT=3001

# Optional: Send confirmation to customer?
CUSTOMER_EMAIL_FIELD=false
